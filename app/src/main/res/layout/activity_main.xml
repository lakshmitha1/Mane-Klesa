<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F5FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- TOP PURPLE CARD -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="430dp"
            app:cardCornerRadius="35dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="#6C4CF1"
                android:padding="20dp">

                <!-- WELCOME -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome to"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="20dp"/>

                <!-- APP NAME -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mane-Kelsa"
                    android:textStyle="bold"
                    android:textSize="40sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"/>

                <!-- SUBTITLE -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your trusted partner\nfor every work"
                    android:textAlignment="center"
                    android:textSize="18sp"
                    android:textColor="#EDE7FF"
                    android:layout_marginTop="12dp"/>

                <!-- WORKER EMOJI -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👨‍🔧"
                    android:textSize="130sp"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- SPACE -->

        <Space
            android:layout_width="match_parent"
            android:layout_height="25dp"/>

        <!-- FIND WORKERS -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="75dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="18dp">

            <Button
                android:id="@+id/btnFindWorkers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="🔍  Find Workers"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:background="#6C4CF1"/>
        </androidx.cardview.widget.CardView>

        <!-- REGISTER -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="75dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="18dp">

            <Button
                android:id="@+id/btnRegisterWorker"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="📝  Register as Worker"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#6C4CF1"
                android:background="#FFFFFF"/>
        </androidx.cardview.widget.CardView>

        <!-- LOGIN -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="75dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="18dp">

            <Button
                android:id="@+id/btnWorkerLogin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="👷  Worker Login"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#6C4CF1"
                android:background="#FFFFFF"/>
        </androidx.cardview.widget.CardView>

        <!-- BOOKINGS -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="75dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp">

            <Button
                android:id="@+id/btnMyBookings"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="📅  My Bookings"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#6C4CF1"
                android:background="#FFFFFF"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>