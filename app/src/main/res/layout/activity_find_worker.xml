<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F0FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- BACK BUTTON -->

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7E57C2"
            android:layout_marginBottom="15dp" />

        <!-- TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find Workers"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#5B2C91"
            android:layout_gravity="center"
            android:paddingBottom="6dp" />

        <!-- SUBTITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Search trusted workers near you"
            android:textSize="16sp"
            android:textColor="#7E57C2"
            android:layout_gravity="center"
            android:paddingBottom="20dp" />

        <!-- SEARCH BOX -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#E9DDFF"
            android:padding="10dp"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:elevation="4dp">

            <EditText
                android:id="@+id/editSearch"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:hint="Search worker..."
                android:textColor="#000000"
                android:textColorHint="#7E57C2"
                android:background="#FFFFFF"
                android:padding="12dp" />

            <Button
                android:id="@+id/btnSearch"
                android:layout_width="wrap_content"
                android:layout_height="55dp"
                android:text="🔍"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#7E57C2"
                android:layout_marginStart="10dp" />
        </LinearLayout>

        <!-- WORKERS CONTAINER -->

        <LinearLayout
            android:id="@+id/workersContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp" />

    </LinearLayout>

</ScrollView>